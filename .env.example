# PolyHermes 环境变量配置示例
# 复制本文件为 .env 并填写实际值后，run_backend_local.sh / scripts/tmux-services.sh / polymtrade-bridge/start.sh
# 以及 docker-compose 都会自动读取。

# ==========================================
# 1. 共享基础配置
# ==========================================
TZ=Asia/Shanghai
SERVER_PORT=8000
MYSQL_PORT=3307
SPRING_PROFILES_ACTIVE=prod

# ==========================================
# 2. 数据库（本地开发默认 Docker MySQL 3307）
# ==========================================
# 注意：容器内运行时，DB_URL 应使用服务名，例如 jdbc:mysql://mysql:3306/polyhermes?...
# 本地裸机运行时，使用 localhost:3307
DB_URL=jdbc:mysql://localhost:3307/polyhermes?useSSL=false&serverTimezone=UTC&characterEncoding=utf8&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=
# MySQL root 密码（用于 docker-compose 中 mysql 容器初始化）
MYSQL_ROOT_PASSWORD=${DB_PASSWORD}

# ==========================================
# 3. 安全密钥（必填，生产必须修改）
# ==========================================
# 生成方式：openssl rand -hex 64
JWT_SECRET=
# 生成方式：openssl rand -hex 32
ADMIN_RESET_PASSWORD_KEY=
# 默认与 JWT_SECRET 相同，用于加密私钥/API Secret；如历史数据用旧密钥加密，再配置 ENCRYPTION_KEY_LEGACY
ENCRYPTION_KEY=${JWT_SECRET}
# ENCRYPTION_KEY_LEGACY=
# 前端/内部加密使用，生成方式：openssl rand -hex 32
CRYPTO_SECRET_KEY=

# ==========================================
# 4. 日志级别
# ==========================================
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO

# ==========================================
# 5. Bridge 配置
# ==========================================
BRIDGE_PORT=8080
BRIDGE_WEBHOOK_URL=http://localhost:8080/signal
BRIDGE_PORTFOLIO_URL=http://localhost:8080/portfolio
BRIDGE_BALANCE_URL=http://localhost:8080/balance
BRIDGE_STATUS_URL=http://localhost:8080/status
BROWSER_PROXY=http://127.0.0.1:7890
HEADLESS=false

# Bridge 连接 MySQL（本地开发）
COPY_TRADING_DB_HOST=127.0.0.1
COPY_TRADING_DB_PORT=3307
COPY_TRADING_DB_USER=root
COPY_TRADING_DB_PASSWORD=${DB_PASSWORD}
COPY_TRADING_DB_NAME=polyhermes

# ==========================================
# 6. 前端构建/运行时（可选）
# ==========================================
# 仅在前后端分离部署时需要；本地开发留空，使用 Vite 代理
VITE_API_URL=
VITE_WS_URL=

# ==========================================
# 7. 动态更新
# ==========================================
ALLOW_PRERELEASE=false
GITHUB_REPO=WrBug/PolyHermes
