# Copy these values into /Users/henry/projects/polyhermes/.env to enable unattended Polyburg sync.
# Do not commit real credentials.

# Create an app at https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash

# Keep the session file inside the project so launchd and manual runs share it.
TELEGRAM_SESSION=/Users/henry/projects/polyhermes/.polyburg_telegram
POLYBURG_TELEGRAM_PEER=7698624735
POLYBURG_SYNC_STATE=/Users/henry/projects/polyhermes/.polyburg_telegram_sync_state.json
POLYBURG_DEFAULT_CATEGORY=finance
POLYBURG_SYNC_MODE=web
POLYBURG_PYTHON_BIN=/Library/Frameworks/Python.framework/Versions/3.14/bin/python3
POLYBURG_WEB_PROFILE=/Users/henry/projects/polyhermes/.polyburg_web_profile
POLYBURG_WEB_SYNC_STATE=/Users/henry/projects/polyhermes/.polyburg_web_sync_state.json

# PolyHermes API target.
POLYHERMES_BASE_URL=http://127.0.0.1:8000

# Prefer a current JWT token, or provide username/password so the script can login.
POLYHERMES_TOKEN=your_polyhermes_jwt
# POLYHERMES_USERNAME=admin
# POLYHERMES_PASSWORD=your_password
