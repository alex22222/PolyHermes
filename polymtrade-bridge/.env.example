# Polymtrade Bridge Configuration

# Polymtrade base URL
POLYMTRADE_URL=https://polym.trade

# Browser proxy (optional, e.g. http://host.docker.internal:7890)
BROWSER_PROXY=

# Run browser in headless mode (true/false)
HEADLESS=false

# Browser profile directory (for persistent login session)
BROWSER_PROFILE_DIR=./browser_profile

# Copy-trading rule engine (reads PolyHermes MySQL)
COPY_TRADING_DB_HOST=127.0.0.1
COPY_TRADING_DB_PORT=3307
COPY_TRADING_DB_USER=root
COPY_TRADING_DB_PASSWORD=
COPY_TRADING_DB_NAME=polyhermes
# Optional: restrict to one account's configs. Leave empty to use all enabled configs.
COPY_TRADING_ACCOUNT_ID=

# Bridge identifier used when persisting trade records
BRIDGE_ID=polymtrade-bridge
